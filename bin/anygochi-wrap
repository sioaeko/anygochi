#!/usr/bin/env bash
# anygochi-wrap: Create an anygochi-enabled wrapper for any CLI coding tool.
#
# Usage:
#   anygochi-wrap <toolname>          # wrap a tool in PATH
#   anygochi-wrap <toolname> /path    # wrap a specific binary
#   anygochi-wrap --list              # list currently wrapped tools
#   anygochi-wrap --remove <toolname> # remove a wrapper
#
# Example:
#   anygochi-wrap codex
#   anygochi-wrap aider
#   anygochi-wrap gh

set -euo pipefail

LOCAL_BIN="$HOME/.local/bin"
ANYGOCHI="$LOCAL_BIN/anygochi"

# ── Helpers ───────────────────────────────────────────────────────────────────

die()  { echo "error: $*" >&2; exit 1; }
info() { echo "  $*"; }

require_anygochi() {
    [[ -x "$ANYGOCHI" ]] || die "anygochi not found at $ANYGOCHI"
}

# Find the real binary for a tool name, skipping wrappers in LOCAL_BIN
find_real_binary() {
    local tool="$1"
    # Walk PATH entries; skip our own LOCAL_BIN wrapper if present
    while IFS= read -r -d ':' dir; do
        [[ -z "$dir" ]] && continue
        local candidate="$dir/$tool"
        if [[ -x "$candidate" && "$dir" != "$LOCAL_BIN" ]]; then
            echo "$candidate"
            return 0
        fi
    done <<< "${PATH}:"
    return 1
}

# ── Commands ──────────────────────────────────────────────────────────────────

do_wrap() {
    local tool="$1"
    local real_bin="${2:-}"

    require_anygochi

    # Resolve real binary
    if [[ -z "$real_bin" ]]; then
        real_bin="$(find_real_binary "$tool")" \
            || die "could not find '$tool' in PATH (excluding $LOCAL_BIN)"
    else
        [[ -x "$real_bin" ]] || die "'$real_bin' is not executable"
    fi

    local wrapper="$LOCAL_BIN/$tool"

    # Safety: don't wrap anygochi itself or anygochi-wrap
    [[ "$tool" == "anygochi" || "$tool" == "anygochi-wrap" ]] \
        && die "cannot wrap anygochi itself"

    # Warn if already wrapped
    if [[ -f "$wrapper" ]]; then
        # Check if it's one of ours
        if head -3 "$wrapper" 2>/dev/null | grep -q "^# anygochi wrapper for:"; then
            echo "  '$tool' is already wrapped. Overwriting..."
        else
            die "'$wrapper' exists and is not an anygochi wrapper. Move it first."
        fi
    fi

    mkdir -p "$LOCAL_BIN"

    cat > "$wrapper" <<WRAPPER
#!/usr/bin/env bash
# anygochi wrapper for: $tool
# real binary: $real_bin
# generated by: anygochi-wrap

set -euo pipefail

ANYGOCHI_BIN="$ANYGOCHI"
REAL_BIN="$real_bin"

if [[ -x "\$ANYGOCHI_BIN" && -z "\${ANYGOCHI_WRAPPED:-}" ]]; then
    export ANYGOCHI_WRAPPED=1

    if [[ -n "\${TMUX:-}" ]]; then
        exec "\$REAL_BIN" "\$@"

    elif command -v tmux &>/dev/null; then
        # Not in tmux: build layout in detached session first so tool starts with correct width
        "\$ANYGOCHI_BIN" session "$tool" --silent 2>/dev/null || true
        _sess="anygochi-\$\$"
        _cols="\$(tput cols 2>/dev/null || echo 80)"
        _lines="\$(tput lines 2>/dev/null || echo 24)"
        _main=\$(( _cols - 31 ))
        [[ \$_main -lt 40 ]] && _main=\$_cols
        tmux new-session -d -s "\$_sess" -x "\$_cols" -y "\$_lines" "\$ANYGOCHI_BIN watch"
        tmux split-window -h -b -l "\$_main" -t "\$_sess" \
            "ANYGOCHI_WRAPPED=1 \$REAL_BIN \$(printf '%q ' \"\$@\"); echo; \$ANYGOCHI_BIN show; read -rsp '[press enter to close]'"
        exec tmux attach-session -t "\$_sess"

    else
        # No tmux: show session notification, run tool, show buddy after
        "\$ANYGOCHI_BIN" session "$tool" --silent 2>/dev/null || true
        "\$REAL_BIN" "\$@"
        _exit=\$?
        "\$ANYGOCHI_BIN" show 2>/dev/null || true
        exit \$_exit
    fi
else
    exec "\$REAL_BIN" "\$@"
fi
WRAPPER

    chmod +x "$wrapper"

    # On Windows (MSYS/Git Bash), also generate a .cmd wrapper so that
    # PowerShell and cmd.exe pick it up.
    if [[ "$(uname -s)" == MINGW* || "$(uname -s)" == MSYS* ]]; then
        local win_wrapper="$LOCAL_BIN/$tool.cmd"
        local python_exe
        python_exe="$(cygpath -w "$(command -v python 2>/dev/null || command -v python3 2>/dev/null)")" || true
        local anygochi_win
        anygochi_win="$(cygpath -w "$ANYGOCHI")" || true
        local node_entry=""
        # Try to find the tool's node entry point for the .cmd wrapper
        local npm_root
        npm_root="$(npm root -g 2>/dev/null)" || true
        if [[ -n "$npm_root" ]]; then
            # Attempt common npm entry patterns
            local real_cmd="$LOCAL_BIN/../AppData/Roaming/npm/$tool.cmd"
            [[ -f "$real_cmd" ]] || real_cmd="$(cygpath -u "$npm_root")/../$tool.cmd"
            if [[ -f "$real_cmd" ]]; then
                # Parse original .cmd to find node entry point
                node_entry="$(grep -oP '(?<=node_modules\\\\)[^"]+' "$real_cmd" 2>/dev/null | head -1)" || true
            fi
        fi
        # Determine the launch command for the real tool
        local run_line
        if [[ -n "$node_entry" ]]; then
            local npm_root_win
            npm_root_win="$(cygpath -w "$npm_root")" || true
            run_line="node \"$npm_root_win\\$node_entry\" %*"
        else
            local real_bin_win
            real_bin_win="$(cygpath -w "$real_bin")" || true
            run_line="\"$real_bin_win\" %*"
        fi

        cat > "$win_wrapper" <<CMDWRAPPER
@echo off
chcp 65001 >nul 2>nul
set PYTHONIOENCODING=utf-8
if defined ANYGOCHI_WRAPPED goto :run
set ANYGOCHI_WRAPPED=1
"$python_exe" "$anygochi_win" session $tool --silent 2>nul
powershell -NoProfile -Command "\$env:PYTHONIOENCODING='utf-8'; Start-Process -FilePath '\$env:USERPROFILE\\AppData\\Local\\Programs\\Python\\Python310\\python.exe' -ArgumentList '\$env:USERPROFILE\\.local\\bin\\anygochi','watch'"
:run
$run_line
CMDWRAPPER
        echo "  ✓ Created Windows wrapper: $win_wrapper"
    fi

    echo "  ✓ Wrapped '$tool'"
    echo "    wrapper : $wrapper"
    echo "    real    : $real_bin"
    echo ""
    echo "  Run 'anygochi session $tool' is called automatically on each launch."
    echo "  Your buddy is at: $ANYGOCHI"
}

do_remove() {
    local tool="$1"
    local wrapper="$LOCAL_BIN/$tool"
    [[ -f "$wrapper" ]] || die "no wrapper found at $wrapper"
    head -3 "$wrapper" 2>/dev/null | grep -q "^# anygochi wrapper for:" \
        || die "'$wrapper' doesn't look like an anygochi wrapper"
    rm "$wrapper"
    # Also remove .cmd wrapper on Windows
    [[ -f "$wrapper.cmd" ]] && rm "$wrapper.cmd"
    echo "  ✓ Removed wrapper for '$tool'"
}

do_list() {
    echo ""
    echo "  Wrapped tools in $LOCAL_BIN:"
    echo ""
    local found=0
    for f in "$LOCAL_BIN"/*; do
        [[ -f "$f" ]] || continue
        # Skip .cmd files (listed alongside their bash counterpart)
        [[ "$f" == *.cmd ]] && continue
        # Match only generated wrappers (have both marker lines)
        if head -3 "$f" 2>/dev/null | grep -q "^# anygochi wrapper for:"; then
            local tool
            tool="$(basename "$f")"
            local real
            real="$(grep "^# real binary:" "$f" | cut -d: -f2- | xargs)"
            local suffix=""
            [[ -f "$f.cmd" ]] && suffix=" (+.cmd)"
            printf "    %-16s → %s%s\n" "$tool" "${real:-unknown}" "$suffix"
            found=1
        fi
    done
    [[ $found -eq 0 ]] && echo "    (none yet — run: anygochi-wrap <toolname>)"
    echo ""
}

# ── Main ──────────────────────────────────────────────────────────────────────

USAGE="Usage: anygochi-wrap <toolname> [/path/to/real/binary]
       anygochi-wrap --list
       anygochi-wrap --remove <toolname>

Examples:
  anygochi-wrap codex
  anygochi-wrap aider
  anygochi-wrap gh /usr/bin/gh
  anygochi-wrap --list
  anygochi-wrap --remove aider
"

case "${1:-}" in
    ""|"-h"|"--help"|"help")
        echo "$USAGE" ;;
    "--list"|"list")
        do_list ;;
    "--remove"|"remove")
        [[ -n "${2:-}" ]] || die "specify a tool name to remove"
        do_remove "$2" ;;
    -*)
        die "unknown option: $1" ;;
    *)
        do_wrap "$1" "${2:-}" ;;
esac
