#!/usr/bin/env bash
# openbuddy-launcher: Robust tool execution with delayed buddy split and error capture.

set -euo pipefail

TOOL_NAME="$1"
REAL_BIN="$2"
shift 2

# 1. TRAP ERRORS: If the tool crashes, don't let the pane disappear.
handle_exit() {
    local exit_code=$?
    if [[ $exit_code -ne 0 ]]; then
        echo -e "\n\033[1;31m[openbuddy] Tool '$TOOL_NAME' exited with code $exit_code.\033[0m"
        read -rsp "[press enter to close this pane]"
    fi
}
trap handle_exit EXIT

# 2. START DELAYED BUDDY (Background)
# This waits for the tool to be fully loaded before changing the layout.
# This prevents the focus/resize events that cause the auto-input bug.
if [[ -n "${TMUX:-}" ]]; then
    (
        sleep 2.5
        # Split window ONLY if it hasn't been split yet
        if [[ $(tmux list-panes | wc -l) -eq 1 ]]; then
            tmux split-window -h -b -d -l 31 "openbuddy watch" 2>/dev/null || true
        fi
    ) &
fi

# 3. AGGRESSIVE FLUSH (just in case)
_flush_stdin() {
    stty -echo 2>/dev/null || true
    printf '\e[?1004l\e[?2004l' 2>/dev/null || true
    sleep 0.5
    python3 -c 'import sys, termios; termios.tcflush(sys.stdin, termios.TCIFLUSH)' 2>/dev/null || true
    while read -r -t 0.1 -n 10000 _trash; do :; done 2>/dev/null || true
    stty echo 2>/dev/null || true
}
_flush_stdin

# 4. EXECUTE TOOL
echo -e "\033[1;34m[openbuddy] Launching $TOOL_NAME...\033[0m"
exec "$REAL_BIN" "$@"
